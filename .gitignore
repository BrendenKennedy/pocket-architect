# Terraform files
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Variable files (may contain sensitive info)
terraform.tfvars
terraform.tfvars.bak
*.auto.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash log files
crash.log
crash.*.log

# Ignore any .tfvars files that are generated
*.tfvars.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# OS files
.DS_Store
Thumbs.db

